# Base de datos PostgreSQL dedicada de Santiago (Railway)
DATABASE_URL=postgresql://user:pass@host:port/dbname

# API key que Power Automate manda en el header X-API-Key para ingesta de consultas del Forms
SDE_API_KEY=cambiar-por-una-clave-larga

# Clave para firmar las cookies de sesión
SECRET_KEY=cambiar-por-un-secreto-largo-aleatorio
